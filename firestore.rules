rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isChatParticipant(chatId) {
      return signedIn()
        && exists(/databases/$(database)/documents/chats/$(chatId))
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if isSelf(userId);
    }

    match /chats/{chatId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if signedIn() && request.auth.uid in resource.data.participants;
      allow delete: if signedIn() && request.auth.uid in resource.data.participants;
    }

    match /messages/{messageId} {
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.senderId;

      allow read: if signedIn()
        && (request.auth.uid == resource.data.senderId
          || request.auth.uid == resource.data.receiverId
          || isChatParticipant(resource.data.chatId));

      allow update: if signedIn() && request.auth.uid == resource.data.senderId;
      allow delete: if signedIn() && request.auth.uid == resource.data.senderId;
    }
  }
}