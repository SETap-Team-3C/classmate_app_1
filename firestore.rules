rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isChatParticipant(chatId) {
      return signedIn()
        && exists(/databases/$(database)/documents/chats/$(chatId))
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function validChatParticipants(participants) {
      return participants is list
        && participants.size() == 2
        && request.auth.uid in participants;
    }

    function sameChatParticipants(a, b) {
      return a is list
        && b is list
        && a.size() == 2
        && b.size() == 2
        && a.hasAll(b)
        && b.hasAll(a);
    }

    function validMessageCreateSchema() {
      return request.resource.data.keys().hasAll([
          'chatId',
          'senderId',
          'receiverId',
          'messageType',
          'text',
          'timestamp',
          'read',
          'readAt',
          'readBy'
        ])
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.receiverId != request.auth.uid
        && request.resource.data.messageType in ['text', 'image', 'document', 'contact']
        && request.resource.data.timestamp is timestamp
        && request.resource.data.read == false
        && request.resource.data.readAt == null
        && request.resource.data.readBy == null
        && (
          (request.resource.data.messageType == 'text'
            && request.resource.data.keys().hasOnly([
              'chatId',
              'senderId',
              'receiverId',
              'messageType',
              'text',
              'timestamp',
              'read',
              'readAt',
              'readBy'
            ])
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0)
          ||
          (request.resource.data.messageType in ['image', 'document']
            && request.resource.data.keys().hasOnly([
              'chatId',
              'senderId',
              'receiverId',
              'messageType',
              'text',
              'timestamp',
              'read',
              'readAt',
              'readBy',
              'fileUrl',
              'fileName',
              'mimeType',
              'fileSize'
            ])
            && request.resource.data.fileUrl is string
            && request.resource.data.fileUrl.size() > 0
            && request.resource.data.fileName is string
            && request.resource.data.fileName.size() > 0
            && request.resource.data.mimeType is string
            && request.resource.data.mimeType.size() > 0
            && request.resource.data.fileSize is int
            && request.resource.data.fileSize > 0)
          ||
          (request.resource.data.messageType == 'contact'
            && request.resource.data.keys().hasOnly([
              'chatId',
              'senderId',
              'receiverId',
              'messageType',
              'text',
              'timestamp',
              'read',
              'readAt',
              'readBy',
              'contactData'
            ])
            && request.resource.data.contactData is map)
        );
    }

    function validMessageUpdateSchema() {
      // Only allow updates to a small set of message fields so partial updates
      // (arrayUnion/arrayRemove) used by the client are permitted while
      // preventing arbitrary schema changes.
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.size() > 0
        && changed.hasOnly([
          'deletedFor',
          'starredBy',
          'isDeleted',
          'text',
          'editedAt',
          'read',
          'readAt',
          'readBy',
          'reactions'
        ]);
    }

    function validPostCreateSchema() {
      return request.resource.data.keys().hasAll([
          'userId',
          'userName',
          'userPhotoUrl',
          'text',
          'imageUrl',
          'createdAt',
          'likeCount',
          'commentCount',
          'isPinned',
          'pinnedAt'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userName is string
        && request.resource.data.userPhotoUrl is string
        && request.resource.data.text is string
        && request.resource.data.imageUrl is string
        && request.resource.data.likeCount == 0
        && request.resource.data.commentCount == 0
        && request.resource.data.isPinned == false
        && request.resource.data.pinnedAt == null;
    }

    function validPostUpdateSchema() {
      return request.resource.data.userId == resource.data.userId
        && request.resource.data.userName is string
        && request.resource.data.userPhotoUrl is string
        && request.resource.data.text is string
        && request.resource.data.imageUrl is string
        && request.resource.data.isPinned is bool;
    }

    function validCommentCreateSchema(collectionName, postId) {
      return request.resource.data.keys().hasAll([
          'userId',
          'userName',
          'text',
          'createdAt',
          'parentCommentId'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userName is string
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && (
          request.resource.data.parentCommentId == null
          || (
            request.resource.data.parentCommentId is string
            && exists(
              /databases/$(database)/documents/$(collectionName)/$(postId)/comments/$(request.resource.data.parentCommentId)
            )
          )
        );
    }

    function isPostOwner(collectionName, postId) {
      return signedIn()
        && exists(/databases/$(database)/documents/$(collectionName)/$(postId))
        && get(/databases/$(database)/documents/$(collectionName)/$(postId)).data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if isSelf(userId);
    }

    match /chats/{chatId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn()
        && validChatParticipants(request.resource.data.participants);
      allow update: if signedIn()
        && request.auth.uid in resource.data.participants
        && sameChatParticipants(
          request.resource.data.participants,
          resource.data.participants
        );
      allow delete: if signedIn() && request.auth.uid in resource.data.participants;
    }

    match /messages/{messageId} {
      allow create: if signedIn()
        && request.resource.data.senderId == request.auth.uid
        && isChatParticipant(request.resource.data.chatId)
        && validMessageCreateSchema();

      allow read: if signedIn()
        && (
          request.auth.uid == resource.data.senderId ||
          request.auth.uid == resource.data.receiverId
        );

      // Allow participants (sender or receiver) to make small updates such as
      // marking read, adding/removing starredBy, or adding their uid to
      // deletedFor. The update schema is restricted by validMessageUpdateSchema().
      allow update: if signedIn()
        && isChatParticipant(resource.data.chatId)
        && (
          request.auth.uid == resource.data.senderId ||
          request.auth.uid == resource.data.receiverId
        )
        && validMessageUpdateSchema();

      // Only the original sender may delete the message document entirely.
      allow delete: if signedIn()
        && request.auth.uid == resource.data.senderId;
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() && validPostCreateSchema();
      allow update: if signedIn()
        && request.auth.uid == resource.data.userId
        && validPostUpdateSchema();
      allow delete: if signedIn() && request.auth.uid == resource.data.userId;

      match /likes/{likeId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.userId == request.auth.uid;
        allow delete: if signedIn()
          && request.auth.uid == resource.data.userId;
      }

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn() && validCommentCreateSchema('posts', postId);
        allow update: if signedIn()
          && (
            request.auth.uid == resource.data.userId
            || isPostOwner('posts', postId)
          );
        allow delete: if signedIn()
          && request.auth.uid == resource.data.userId;

        match /likes/{likeId} {
          allow read: if signedIn();
          allow create: if signedIn()
            && request.resource.data.userId == request.auth.uid;
          allow delete: if signedIn()
            && request.auth.uid == resource.data.userId;
        }
      }
    }

    match /posts_mates/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() && validPostCreateSchema();
      allow update: if signedIn()
        && request.auth.uid == resource.data.userId
        && validPostUpdateSchema();
      allow delete: if signedIn() && request.auth.uid == resource.data.userId;

      match /likes/{likeId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.userId == request.auth.uid;
        allow delete: if signedIn()
          && request.auth.uid == resource.data.userId;
      }

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn() && validCommentCreateSchema('posts_mates', postId);
        allow update: if signedIn()
          && (
            request.auth.uid == resource.data.userId
            || isPostOwner('posts_mates', postId)
          );
        allow delete: if signedIn()
          && request.auth.uid == resource.data.userId;

        match /likes/{likeId} {
          allow read: if signedIn();
          allow create: if signedIn()
            && request.resource.data.userId == request.auth.uid;
          allow delete: if signedIn()
            && request.auth.uid == resource.data.userId;
        }
      }
    }

    match /posts_class/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() && validPostCreateSchema();
      allow update: if signedIn()
        && request.auth.uid == resource.data.userId
        && validPostUpdateSchema();
      allow delete: if signedIn() && request.auth.uid == resource.data.userId;

      match /likes/{likeId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.userId == request.auth.uid;
        allow delete: if signedIn()
          && request.auth.uid == resource.data.userId;
      }

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn() && validCommentCreateSchema('posts_class', postId);
        allow update: if signedIn()
          && (
            request.auth.uid == resource.data.userId
            || isPostOwner('posts_class', postId)
          );
        allow delete: if signedIn()
          && request.auth.uid == resource.data.userId;

        match /likes/{likeId} {
          allow read: if signedIn();
          allow create: if signedIn()
            && request.resource.data.userId == request.auth.uid;
          allow delete: if signedIn()
            && request.auth.uid == resource.data.userId;
        }
      }
    }
  }
}